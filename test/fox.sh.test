#!/usr/bin/env bats

bats_require_minimum_version 1.5.0

SOURCE=src/fox-sh

@test "ensure app exists" {
  run stat $SOURCE/fox.sh
  [ $status = 0 ]
}

@test "ensure unknown command gracefully fails" {
  run -127 $SOURCE/fox.sh randomcommand
}

# --- update / uninstall

@test "ensure command : update : fails gracefully without network or install dir" {
  FOX_HOME=$(mktemp -d)
  mkdir -p "$FOX_HOME/bin"
  HOME="$FOX_HOME" run $SOURCE/fox.sh update
  rm -rf "$FOX_HOME"
  [ $status -ne 127 ]
}

@test "ensure command : uninstall : removes install directory" {
  FOX_HOME=$(mktemp -d)
  mkdir -p "$FOX_HOME/.fox/bin"
  touch "$FOX_HOME/.fox/bin/fox"
  HOME="$FOX_HOME" run $SOURCE/fox.sh uninstall
  [ $status = 0 ]
  [ ! -d "$FOX_HOME/.fox" ]
  rm -rf "$FOX_HOME"
}

@test "ensure command : uninstall : fails gracefully when not installed" {
  FOX_HOME=$(mktemp -d)
  HOME="$FOX_HOME" run $SOURCE/fox.sh uninstall
  [ $status = 1 ]
  rm -rf "$FOX_HOME"
}

# --- fox system

@test "ensure command : system : shows subcommand list" {
  run $SOURCE/fox.sh system
  [ $status = 0 ]
  [[ "$output" == *"disk"* ]]
  [[ "$output" == *"memory"* ]]
  [[ "$output" == *"processes"* ]]
  [[ "$output" == *"users"* ]]
  [[ "$output" == *"version"* ]]
  [[ "$output" == *"restart"* ]]
  [[ "$output" == *"notes"* ]]
}

@test "ensure command : system info : works" {
  run $SOURCE/fox.sh system info
  [ $status = 0 ]
}

@test "ensure command : system disk : works" {
  run $SOURCE/fox.sh system disk
  [ $status = 0 ]
}

@test "ensure command : system memory : works" {
  run $SOURCE/fox.sh system memory
  [ $status = 0 ]
}

@test "ensure command : system processes : works" {
  run $SOURCE/fox.sh system processes
  [ $status = 0 ]
}

@test "ensure command : system users : works" {
  run $SOURCE/fox.sh system users
  [ $status = 0 ]
}

@test "ensure command : system version : works" {
  run $SOURCE/fox.sh system version
  [ $status = 0 ]
}

@test "ensure command : system restart : works" {
  run $SOURCE/fox.sh system restart
  [ $status = 0 ]
}

@test "ensure command : system notes : shows reference and local notes sections" {
  run $SOURCE/fox.sh system notes
  [ $status = 0 ]
  [[ "$output" == *"reference"* ]]
  [[ "$output" == *"local notes"* ]]
}

@test "ensure command : system badcmd : exits 0 and shows subcommands" {
  run $SOURCE/fox.sh system badcmd
  [ $status = 0 ]
}

